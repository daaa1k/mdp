[tagpr]
vPrefix = true
releaseBranch = main
# Let GoReleaser create the GitHub Release (draft: true in .goreleaser.yml); tagpr must not
# also create a release or CI can target the wrong release / leave a duplicate draft.
release = false
versionFile = VERSION
command = "mise run prerelease-for-tagpr"
majorLabels = "tagpr:major"
minorLabels = "tagpr:minor"
